PORT=3008
NODE_ENV=development
APP_URL=http://localhost:5173

# Database configuration (Leave blank to fall back to SQLite)
DATABASE_URL=
# SQLite fallback is active if postgres fails to connect
SQLITE_DB_PATH=./src/database/dev.sqlite3

# Redis configuration
REDIS_URL=redis://localhost:6379

# JWT secrets
JWT_SECRET=super_secret_access_token_key_12345
JWT_REFRESH_SECRET=super_secret_refresh_token_key_67890

# AI Configuration (Optional keys; code will fall back to mocked heuristics if empty)
OPENAI_API_KEY=
GEMINI_API_KEY=
